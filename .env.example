APP_ENV=development
APP_DEBUG=true
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=10s
DB_URL=postgres://postgres:password@localhost:5432/appdb?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_CONN_TIMEOUT=5s
DB_MIGRATIONS_DIR=migrations
JWT_SECRET=change-me-in-production-min-16-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
LOCALES_DIR=locales
DEFAULT_LANG=en
